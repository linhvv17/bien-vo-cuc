# Dev: copy từ `.env.example` hoặc giữ file này (gitignored).

# Để trống VITE_API_BASE_URL để dùng proxy `/api` (khuyến nghị). Uncomment dưới để gọi thẳng:
# VITE_API_BASE_URL=http://127.0.0.1:3001

VITE_API_PROXY_TARGET=http://127.0.0.1:3001

# VITE_USE_MOCK=true

VITE_RECAPTCHA_SITE_KEY=
VITE_APP_ENV=development
VITE_APP_NAME=Biển Vô Cực

# VITE_MAPBOX_PUBLIC_TOKEN=pk.your_mapbox_public_token
