# Copy thành `.env.development` (gitignored) để chạy `npm run dev`.
# Cổng Vite cố định 8080 (strictPort) — giữ nguyên qua các lần restart.

# Gọi API: để trống = dùng same-origin `/api` (Vite proxy). Hoặc gọi thẳng backend:
VITE_API_BASE_URL=http://localhost:3001

# Mục tiêu proxy dev: phải trùng cổng API Nest (PORT trong apps/api).
VITE_API_PROXY_TARGET=http://127.0.0.1:3001

# `true` = dữ liệu demo (không gọi API thật). `false` = luôn API thật.
VITE_USE_MOCK=true

VITE_RECAPTCHA_SITE_KEY=
VITE_APP_ENV=development
VITE_APP_NAME=Biển Vô Cực

# Mapbox public token (pk.*) — ảnh bản đồ tĩnh; không commit token thật vào git
VITE_MAPBOX_PUBLIC_TOKEN=
