# Dev: sao chép thành `.env.dev` (gitignored) và chạy `npm run start:dev`.
# Prisma CLI mặc định đọc file tên `.env` — khi cần migrate có thể: `cp .env.dev .env` trong thư mục này.
#
# Cổng cố định dev — giữ nguyên để web/admin/proxy không lệch sau reboot.
PORT=3001

# Local dev (docker compose postgres on localhost:5432)
# Local dev (docker compose postgres on localhost:5433)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5433/DB_NAME

ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me
JWT_EXPIRES_IN=15m
# Refresh token (JWT riêng, rotation mỗi lần gọi POST /auth/refresh)
JWT_REFRESH_SECRET=change-me-refresh
JWT_REFRESH_EXPIRES_IN=7d

# Tides sync — Stormglass (https://stormglass.io). Điền key; để trống thì nút «Sync ngay» sẽ báo rõ, không sync được.
STORMGLASS_API_KEY=
# Tọa độ bãi (Google Maps: https://maps.app.goo.gl/WP2bvGszwnZPFeZk9) — dùng cho triều (Stormglass) & thời tiết.
BEACH_LAT=20.5774021
BEACH_LNG=106.6192557
RUN_TIDE_SYNC_ON_START=false

